# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tuya (smart-home / smart-lock integration)
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_REGION=us
# Optional: skip auto-discovery and use this UID to list devices.
# Find it in Tuya cloud → Devices → Link App Account → UID column.
TUYA_USER_UID=

# Cron (Vercel sends this as a Bearer token to /api/cron/sync).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Energy tariff in UYU per kWh — used to estimate consumption cost on
# /energy. UTE residential general (Uruguay 2026) is roughly 9 UYU/kWh.
# Adjust if you're on a different plan or country.
ENERGY_TARIFF_UYU_PER_KWH=9

# WhatsApp via Kapso (BSP layer over Meta WhatsApp Cloud API).
# Webhook receiver lives at /api/whatsapp.
KAPSO_API_KEY=
KAPSO_WEBHOOK_SECRET=
# Phone number ID of the WhatsApp Business number registered with Kapso/Meta.
# Used by the inbox to send replies. Find it in Kapso → phone numbers.
WHATSAPP_PHONE_NUMBER_ID=
# Set to "false" to disable auto-replies on inbound messages (e.g. during
# debugging or when you want fully manual responses). Default ON.
WHATSAPP_AUTO_REPLY_ENABLED=true
