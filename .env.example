# ─── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional — only needed if you want to run migrations from the repo via
# `pnpm db:apply` instead of pasting SQL into the Supabase SQL editor.
# Get it from Supabase Dashboard → Project Settings → Connect → "Session
# pooler" (NOT direct, NOT transaction pooler). URL-encode special chars
# in the password.
DATABASE_URL=

# ─── App URL ──────────────────────────────────────────────────────────
# Public URL of the app (no trailing slash). Used to build deeplinks in
# WhatsApp messages and daily reports. Default in `src/lib/brand.ts` is
# `https://tero.bot` — only set this if you're forking and serving from
# your own domain.
NEXT_PUBLIC_APP_URL=
# Subdomain that receives Postmark Inbound (Airbnb forwards + utility
# bill PDFs). Optional — leave empty if not using inbound email.
NEXT_PUBLIC_INBOUND_DOMAIN=

# ─── Locale ───────────────────────────────────────────────────────────
# UY/UYU for Uruguay, AR/ARS for Argentina. Override to use elsewhere.
# OPERATOR_TIMEZONE is an IANA tz name; UTC_OFFSET_HOURS is the raw
# offset for code that doesn't want a tz library.
DEFAULT_COUNTRY=UY
DEFAULT_CURRENCY=UYU
OPERATOR_TIMEZONE=America/Montevideo
OPERATOR_UTC_OFFSET_HOURS=-3

# ─── Tuya (smart-home / smart-lock integration) ───────────────────────
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_REGION=us
# Optional: skip auto-discovery and use this UID to list devices.
# Find it in Tuya cloud → Devices → Link App Account → UID column.
TUYA_USER_UID=

# ─── Cron ──────────────────────────────────────────────────────────────
# Vercel sends this as a Bearer token to /api/cron/*. Required.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Energy ────────────────────────────────────────────────────────────
# Energy tariff (local currency per kWh). Used to estimate cost on
# /energy when no per-property tariff is configured. UTE residential
# general (Uruguay 2026) ~ 9 UYU/kWh.
ENERGY_TARIFF_UYU_PER_KWH=9

# ─── WhatsApp via Kapso (BSP layer over Meta WhatsApp Cloud API) ───────
# Webhook receiver lives at /api/whatsapp.
KAPSO_API_KEY=
KAPSO_WEBHOOK_SECRET=
# Phone number ID of the WhatsApp Business number registered with
# Kapso/Meta. Used by the inbox to send replies. Find it in Kapso →
# phone numbers.
WHATSAPP_PHONE_NUMBER_ID=
# Meta WhatsApp Business Account ID — distinct from the phone number ID.
# Needed by the `pnpm wa:templates:submit` / `:status` scripts to
# create and poll message templates. Find it in Meta Business Manager
# → Settings → Accounts → WhatsApp Accounts → "Business Account ID"
# (15-16 numeric digits).
WHATSAPP_WABA_ID=
# Set to "false" to disable auto-replies on inbound messages (e.g.
# during debugging or when you want fully manual responses).
WHATSAPP_AUTO_REPLY_ENABLED=true
# Set to "true" to skip the actual Kapso template send and just log
# what would be sent. Useful while you wait for Meta to approve new
# templates (WIK-124, WIK-125 templates take 24-72h).
MOCK_WHATSAPP_TEMPLATES=false

# ─── Postmark Inbound ──────────────────────────────────────────────────
# Parses Airbnb confirmation/cancellation emails and enriches reservations.
# See /api/inbound. Setup:
#   1. Create a Postmark Inbound server.
#   2. Add MX record on a subdomain (the one you set in
#      NEXT_PUBLIC_INBOUND_DOMAIN above) pointing to inbound.postmarkapp.com.
#   3. In Postmark, set the Inbound webhook to
#      https://<your-host>/api/inbound with Basic Auth
#      (random user:password pair, plug them in below).
#   4. Set a Gmail filter that forwards from:airbnb.com mail to the
#      generated inbound address.
POSTMARK_INBOUND_USER=
POSTMARK_INBOUND_PASSWORD=

# ─── Linear (WIK-97) ──────────────────────────────────────────────────
# Personal API token desde
#   https://linear.app/wikichaves/settings/api → "Personal API keys"
# Necesario para los comandos /linear y /claude del bot de Telegram.
# El token opera bajo TU identidad de Linear — solo lo agrego al deploy
# de Vercel (NO al repo).
LINEAR_API_TOKEN=
# Override del team. Default "WIK".
LINEAR_TEAM_KEY=WIK
# Override del project default. Pone null o vacío si no querés assignment.
LINEAR_DEFAULT_PROJECT_NAME=Tero Bot

# ─── Telegram bot (WIK-97) ────────────────────────────────────────────
# Canal dev/admin separado del bot de WhatsApp (que es para staff).
# Sin restricción 24h-window, soporta code blocks multi-línea, inline
# keyboards, y comandos / con autocomplete.
#
# Setup (todo desde mobile, 5 min):
#   1. Chat con @BotFather → /newbot → nombre → username (terminado en bot)
#      → copiar el token (forma "1234567890:ABCDef...")
#   2. Generar TELEGRAM_WEBHOOK_SECRET:
#        openssl rand -hex 32
#   3. Setear las 3 env vars de abajo en Vercel + redeploy.
#   4. Registrar webhook (one-time):
#        curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://tero.bot/api/telegram&secret_token=<SECRET>"
#   5. Mandar /start al bot desde tu celular → el bot te responde con tu
#      chat_id → copiarlo en TELEGRAM_ADMIN_CHAT_ID y redeployar.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Tu chat_id como user privado. El bot SOLO acepta comandos de este id.
# Si no está seteado, el bot responde a cualquiera con su chat_id (modo
# bootstrap para que lo descubras la primera vez).
TELEGRAM_ADMIN_CHAT_ID=

# ─── Claude (WIK-97) ──────────────────────────────────────────────────
# Anthropic API key para el worker autónomo de GitHub Actions. Genera en
#   https://console.anthropic.com/settings/keys
# NO va acá ni en Vercel — va a GitHub Actions secrets como
# `ANTHROPIC_API_KEY` (visible solo al workflow). Lo documento acá para
# que sepas que existe.
# ANTHROPIC_API_KEY=<sk-ant-...>  (en GitHub Actions, NO acá)

# ─── GitHub PAT (WIK-139) ────────────────────────────────────────────
# Token con scope `workflow` (fine-grained) o `repo` (classic), usado
# por el cmd /work de Telegram para disparar el GitHub Action del
# worker autónomo on-demand vía REST API.
# Generar en:
#   - Classic: https://github.com/settings/tokens → "Generate new token (classic)"
#     → scopes: workflow (+repo si el repo es privado)
#   - Fine-grained: https://github.com/settings/personal-access-tokens
#     → Repository access: wikichaves/tero-bot
#     → Permissions: Actions = Read and write, Metadata = Read
GITHUB_PAT=
