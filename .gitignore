# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example tracked, ignore everything else
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — keep settings.json if you want team-shared rules, but never
# commit .local.json (it can reference local credential paths).
.claude/settings.local.json
.env*.local

# Claude Code MCP config — per-developer, references your own Supabase
# project ref / other MCP server URLs. Copy .mcp.json.example to .mcp.json
# and fill in your values.
.mcp.json

# Local-only working files — assets crudos antes de procesar, drafts, etc.
# No subir al repo (typicamente PSDs, logos originales, samples).
/_archive/

# Reserved para un futuro mecanismo de debug autenticado (MCP server
# local u otro). Hoy NO se usa — el archivo puede estar presente con
# un token random pero no hay código que lo lea. NUNCA committear.
/.claude-debug-token

# WIK-186 follow-up: stats.generated.json se regenera siempre vía el
# script `prebuild`/`predev` (GH API → git local fallback), y Vercel
# lo crea fresh en cada build. Trackearlo causaba conflicts recurrentes
# en branches paralelas porque cada commit lo regenera con un commits
# count distinto. Ahora vive solo localmente / en el build artifact.
/src/lib/landing/stats.generated.json
