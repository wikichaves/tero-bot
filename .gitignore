# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example tracked, ignore everything else
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — keep settings.json if you want team-shared rules, but never
# commit .local.json (it can reference local credential paths).
.claude/settings.local.json
.env*.local

# Local-only working files — assets crudos antes de procesar, drafts, etc.
# No subir al repo (typicamente PSDs, logos originales, samples).
/_archive/
